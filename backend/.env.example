# Proveedor de LLM: auto | gemini | echo
# - auto:   usa Gemini si hay GEMINI_API_KEY, si no responde en modo básico (echo).
# - gemini: fuerza Gemini (falla si no hay API key).
# - echo:   modo sin IA, sin red (útil para tests / demo offline).
LLM_PROVIDER=auto

# API key de Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Opcionales (valores por defecto razonables):
# GEMINI_MODEL=gemini-2.5-flash          # más capaz: gemini-3.5-flash | más barato: gemini-2.5-flash-lite
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# GEMINI_EMBEDDING_DIM=768               # NO cambiar después de embedear el corpus

# Base de datos (Postgres + pgvector).
# Local (Docker, make db-up):
DATABASE_URL=postgresql://jubigestor:jubigestor@localhost:5432/jubigestor
# Producción: pegar la connection string de Neon.
